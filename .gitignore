tmp-*
*.log
server-dev.log
client-dev.log

# ── Node ─────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Next.js ──────────────────────────────────────────────────────
client/.next/
client/out/

# ── Yüklenen dosyalar (lokal depolama, üretimde S3/R2 kullanılır) ─
