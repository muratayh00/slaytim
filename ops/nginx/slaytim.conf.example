# Slaytim production reverse-proxy example
# App: slaytim.com/www -> Next.js (client)
# API: api.slaytim.com -> Express (server)

upstream slaytim_app {
  server 127.0.0.1:3000;
  keepalive 64;
}

upstream slaytim_api {
  server 127.0.0.1:5001;
  keepalive 64;
}

# Force apex canonical (www -> non-www)
server {
  listen 80;
  server_name www.slaytim.com;
  return 301 https://slaytim.com$request_uri;
}

server {
  listen 80;
  server_name slaytim.com;
  return 301 https://slaytim.com$request_uri;
}

server {
  listen 80;
  server_name api.slaytim.com;
  return 301 https://api.slaytim.com$request_uri;
}

# App domain (Cloudflare Full (strict) + origin cert)
server {
  listen 443 ssl http2;
  server_name slaytim.com;

  ssl_certificate /etc/ssl/certs/slaytim-origin.pem;
  ssl_certificate_key /etc/ssl/private/slaytim-origin.key;

  add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

  location / {
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 90;
    proxy_pass http://slaytim_app;
  }
}

# API domain
server {
  listen 443 ssl http2;
  server_name api.slaytim.com;

  ssl_certificate /etc/ssl/certs/slaytim-origin.pem;
  ssl_certificate_key /etc/ssl/private/slaytim-origin.key;

  add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

  location / {
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_read_timeout 120;
    proxy_pass http://slaytim_api;
  }
}
