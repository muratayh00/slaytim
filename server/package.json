{
  "name": "slaytim-server",
  "version": "1.0.0",
  "description": "Slaytim.com backend API",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "worker:conversion": "node src/workers/conversion.worker.js",
    "worker:conversion:redis": "node scripts/worker-conversion-redis.js",
    "worker:preview": "node src/workers/preview.worker.js",
    "redis:up": "docker compose -f docker-compose.redis.yml up -d",
    "redis:down": "docker compose -f docker-compose.redis.yml down",
    "redis:logs": "docker compose -f docker-compose.redis.yml logs -f redis",
    "redis:check": "node scripts/redis-check.js",
    "staging:up": "docker compose -f docker-compose.staging.yml up -d --build",
    "staging:down": "docker compose -f docker-compose.staging.yml down",
    "release:mark": "node scripts/release-mark.js",
    "release:rollback": "node scripts/release-rollback.js",
    "admin:create": "node scripts/create-admin.js",
    "content:reset:dry": "node scripts/reset-all-content.js",
    "content:reset": "node scripts/reset-all-content.js --confirm",
    "load:smoke": "node scripts/load-smoke.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:migrate:sqlite-to-postgres:dry": "node scripts/migrate-sqlite-to-postgres.js --dry-run",
    "db:migrate:sqlite-to-postgres": "node scripts/migrate-sqlite-to-postgres.js --reset",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "repair:missing-slide-sources": "node scripts/repair-missing-slide-sources.js",
    "db:seed:categories": "node scripts/seed-categories.js",
    "preflight:prod": "node ../scripts/preflight-launch.mjs --url https://slaytim.com --api-url https://api.slaytim.com/api",
    "preflight:staging": "node ../scripts/preflight-launch.mjs --url https://staging.slaytim.com --api-url https://api-staging.slaytim.com/api",
    "staging:proof": "node scripts/staging-proof.mjs",
    "conversion:recover-failed": "node scripts/recover-failed-conversions.js",
    "conversion:reclassify-invalid": "node scripts/reclassify-invalid-conversions.js",
    "preview:backfill": "node scripts/backfill-preview-assets.js",
    "preview:backfill:dry": "node scripts/backfill-preview-assets.js --dry-run",
    "preview:backfill:top": "BACKFILL_LIMIT=100 node scripts/backfill-preview-assets.js",
    "preview:report": "bash scripts/preview-backfill-report.sh",
    "preview:monitor": "node scripts/monitor-preview-worker.js",
    "pm2:health": "bash scripts/pm2-health-check.sh",
    "backup:check": "bash scripts/backup-check.sh",
    "smoke:prod": "node scripts/smoke-test-prod.mjs",
    "seo:check": "node scripts/seo-check.mjs",
    "tags:recompute-quality": "node scripts/recompute-tag-quality.js",
    "ops:weekly": "bash scripts/weekly-ops.sh",
    "security:check": "bash scripts/security-check.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.883.0",
    "@aws-sdk/s3-request-presigner": "^3.883.0",
    "@prisma/client": "^5.10.0",
    "@sentry/node": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.72.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "resend": "^4.8.0",
    "sharp": "^0.33.5",
    "sqlite3": "^6.0.1",
    "winston": "^3.11.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jest": "^29",
    "jest": "^29",
    "nodemon": "^3.0.3",
    "prisma": "^5.10.0"
  }
}
