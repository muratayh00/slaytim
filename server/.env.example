# Slaytim backend environment template (development-friendly)
# Copy this file to .env and fill values.
#   cp .env.example .env

# Database (Supabase PostgreSQL)
# Runtime: Transaction pooler (IPv4, 6543)
# Migrations/introspection: use DIRECT_URL (5432) when possible
DATABASE_URL="postgresql://postgres.jzofovpvgenicknaqfim:<SUPABASE_DB_PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?schema=public&pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.jzofovpvgenicknaqfim:<SUPABASE_DB_PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?schema=public&pgbouncer=true&sslmode=require"
SQLITE_MIGRATION_URL="file:./prisma/dev.db"

# Auth
JWT_SECRET="replace_with_long_random_secret"
AUTH_COOKIE_NAME="slaytim_auth"
CSRF_COOKIE_NAME="slaytim_csrf"
AUTH_COOKIE_DOMAIN=""
AUTH_COOKIE_SAME_SITE="lax"
AUTH_COOKIE_SECURE=false

# Server
PORT=5001
CLIENT_URL="http://localhost:3000"
SITE_URL="http://localhost:3000"
TRUST_PROXY=0
BLOCKED_IPS=""
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# LibreOffice conversion
LIBREOFFICE_PATH=""
LIBREOFFICE_REQUIRED=true

# Redis / BullMQ
REDIS_URL="redis://127.0.0.1:6379"
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0
REDIS_ENABLED=false

# Conversion queue
CONVERSION_QUEUE_NAME="slide-conversion"
CONVERSION_ATTEMPTS=5
CONVERSION_BACKOFF_MS=5000
CONVERSION_WORKER_CONCURRENCY=2
CONVERSION_LOCK_DURATION_MS=120000
CONVERSION_LOCAL_FALLBACK=true
CONVERSION_LOCAL_MAX_ATTEMPTS=5
CONVERSION_LOCAL_RETRY_MS=5000
CONVERSION_SANDBOX_DOCKER=false
CONVERSION_SANDBOX_IMAGE=lscr.io/linuxserver/libreoffice:latest
CONVERSION_SANDBOX_SOFFICE=/usr/bin/soffice

# Storage
# s3 | r2 | empty(local dev only)
STORAGE_DRIVER=""
ALLOW_LOCAL_STORAGE_DEV=true
STORAGE_BUCKET=""
STORAGE_REGION="auto"
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_SIGNED_URL_TTL_SECONDS=3600

# Transactional e-mail — Resend (https://resend.com)
# Production: set RESEND_API_KEY to your live key (re_xxxx…)
# Development: leave blank → emails are skipped and logged to console
RESEND_API_KEY=""
EMAIL_FROM="Slaytim <hello@slaytim.com>"

# Monitoring
SENTRY_DSN=""
ALERT_WEBHOOK_URL=""
STUCK_JOB_POLL_MS=60000
STUCK_JOB_THRESHOLD_MS=600000

# ClamAV
CLAMAV_REQUIRED=false
CLAMSCAN_PATH=""

# Recommendation rollout
REC_ENABLED=true
REC_SHADOW_MODE=true
REC_SERVE_SLIDEO_FEED=false
REC_CANARY_PERCENT=0

# Slideo experiment
SLIDEO_FEED_EXPERIMENT_ENABLED=true
SLIDEO_FEED_EXPERIMENT="feed_v2_ab"

# Dedup TTL
VIEW_DEDUP_TTL_SECONDS=30

# AI Summary (BLUF blocks on slide pages)
# Set ONE of the API keys to enable automatic generation. Both keys are optional —
# if neither is present the feature is gracefully disabled (slides still work fine).
#   Priority: ANTHROPIC_API_KEY (Claude 3.5 Haiku) → OPENAI_API_KEY (GPT-4o-mini)
# Leave blank to disable AI summaries (manual aiSummary via DB is still respected).
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
# AI_SUMMARY_ENABLED=true          # set to false to hard-disable even with a key
# AI_SUMMARY_DRY_RUN=false         # set to true to test UI without calling any LLM
# AI_SUMMARY_MODEL=claude-3-5-haiku-latest    # Anthropic model override
# AI_SUMMARY_OPENAI_MODEL=gpt-4o-mini         # OpenAI model override
# AI_SUMMARY_MAX_INPUT_CHARS=18000
# AI_SUMMARY_TIMEOUT_MS=30000

# Process / logging
API_INSTANCES=max
LOG_LEVEL=info
LOG_FILE=""
