NODE_ENV=production
PORT=5001
CLIENT_URL=https://slaytim.com
TRUST_PROXY=1
BLOCKED_IPS=
NEXT_PUBLIC_SITE_URL=https://slaytim.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# REQUIRED: generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

AUTH_COOKIE_NAME=slaytim_auth
CSRF_COOKIE_NAME=slaytim_csrf
AUTH_COOKIE_DOMAIN=.slaytim.com
AUTH_COOKIE_SAME_SITE=strict
AUTH_COOKIE_SECURE=true

# Runtime: Supabase Transaction Pooler (IPv4 compatible, pgbouncer)
# SECURITY: do not use Supabase Data API/JS keys in this project.
DATABASE_URL=postgresql://postgres.jzofovpvgenicknaqfim:<SUPABASE_DB_PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?schema=public&pgbouncer=true&sslmode=require
# Prisma migrate/introspection: prefer direct URL if network supports it.
DIRECT_URL=postgresql://postgres.jzofovpvgenicknaqfim:<SUPABASE_DB_PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?schema=public&pgbouncer=true&sslmode=require
SQLITE_MIGRATION_URL=file:./prisma/dev.db

SENTRY_DSN=

REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

CONVERSION_QUEUE_NAME=slide-conversion
CONVERSION_ATTEMPTS=5
CONVERSION_BACKOFF_MS=5000
CONVERSION_WORKER_CONCURRENCY=2
CONVERSION_LOCK_DURATION_MS=120000
CONVERSION_LOCAL_FALLBACK=false
LIBREOFFICE_REQUIRED=true

CONVERSION_SANDBOX_DOCKER=true
CONVERSION_SANDBOX_IMAGE=lscr.io/linuxserver/libreoffice:latest
CONVERSION_SANDBOX_SOFFICE=/usr/bin/soffice

# REQUIRED: s3 or r2 (local fallback disabled in production)
STORAGE_DRIVER=s3
ALLOW_LOCAL_STORAGE_DEV=false
STORAGE_BUCKET=
STORAGE_REGION=auto
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_SIGNED_URL_TTL_SECONDS=3600

# REQUIRED in production hardening
CLAMAV_REQUIRED=true
CLAMSCAN_PATH=

# Worker heartbeat
WORKER_HEARTBEAT_PATH=/tmp/worker-heartbeat
WORKER_HEARTBEAT_INTERVAL_MS=30000

# Transactional e-mail — Resend
# REQUIRED in production: obtain from https://resend.com/api-keys
RESEND_API_KEY=REPLACE_WITH_YOUR_RESEND_API_KEY
EMAIL_FROM=Slaytim <hello@slaytim.com>

# AI Summary — OPTIONAL. Set one key to enable automatic BLUF blocks on slide pages.
# Priority: ANTHROPIC_API_KEY (Claude 3.5 Haiku) → OPENAI_API_KEY (GPT-4o-mini)
# Leave both blank: feature is gracefully disabled; manual aiSummary in DB still renders.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
