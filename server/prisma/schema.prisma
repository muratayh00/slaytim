// Records all sensitive admin actions for accountability.
model AdminLog {
  id         Int      @id @default(autoincrement())
  adminId    Int      @map("admin_id")
  action     String   // ban_user | mute_user | warn_user | hide_content | restore_content | delete_content | delete_slideo | set_priority | resolve_report
  targetType String?  @map("target_type") // user | topic | slide | comment | slideo | report
  targetId   Int?     @map("target_id")
  meta       String?  // JSON string with extra context
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  admin User @relation("adminLogs", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_logs")
}
