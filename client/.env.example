# Slaytim frontend env template
# Copy to .env.local for local development, and configure these in Vercel for production.

# Local defaults
NEXT_PUBLIC_API_URL=http://localhost:5001/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_UPLOAD_HOST=
NEXT_PUBLIC_EMBED_ALLOWED_PARENTS=http://localhost:3000

# Production values (Vercel)
# NEXT_PUBLIC_API_URL=https://api.slaytim.com/api
# NEXT_PUBLIC_SITE_URL=https://slaytim.com
# NEXT_PUBLIC_UPLOAD_HOST=https://api.slaytim.com
# NEXT_PUBLIC_EMBED_ALLOWED_PARENTS=https://slaytim.com https://www.slaytim.com

# Analytics — Google Analytics 4
# Format: G-XXXXXXXXXX (Measurement ID, GA4 panelinden alınır)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-124Q0M80WR

# Ads (optional) — her slot ayrı bir AdSense reklam birimi
# AdSense publisher ID (ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_ID=

# Placement slot ID'leri (AdSense panelinden alınır)
NEXT_PUBLIC_ADSENSE_SLOT_TOP_BANNER=         # Leaderboard 728x90 — sayfa üstü
NEXT_PUBLIC_ADSENSE_SLOT_IN_FEED=            # Fluid / infeed — liste içi native
NEXT_PUBLIC_ADSENSE_SLOT_RIGHT_RAIL_1=       # Rectangle 300x250 — sağ sidebar 1
NEXT_PUBLIC_ADSENSE_SLOT_RIGHT_RAIL_2=       # Rectangle 300x250 — sağ sidebar 2
NEXT_PUBLIC_ADSENSE_SLOT_RIGHT_RAIL_3=       # Rectangle 300x250 — sağ sidebar 3
NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM_BANNER=      # Leaderboard 728x90 — sayfa altı
NEXT_PUBLIC_ADSENSE_SLOT_STICKY_MOBILE=      # Leaderboard-sm 320x50 — mobil sticky
NEXT_PUBLIC_ADSENSE_SLOT_SLIDEO_INFEED=      # Fluid — Slideo static reklam kartı
NEXT_PUBLIC_ADSENSE_SLOT_SLIDEO_VIDEO=       # Fluid — Slideo video reklam kartı
NEXT_PUBLIC_ADSENSE_SLOT_REWARDED=          # Rewarded — kullanıcı opt-in video
NEXT_PUBLIC_ADSENSE_SLOT_SPONSOR_CARD=       # Sponsor kart (varsa)

# Eski slot ID'ler (geriye dönük uyumluluk için korunuyor — yeni kod yukarıdakileri kullanır)
NEXT_PUBLIC_ADSENSE_SLOT_HOME_MID=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_SLIDE_DETAIL=
NEXT_PUBLIC_ADSENSE_SLOT_SLIDE_MID=
NEXT_PUBLIC_ADSENSE_SLOT_TOPIC_DETAIL=
NEXT_PUBLIC_ADSENSE_SLOT_TOPIC_MID=

# Error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=

# SECURITY POLICY
# Do NOT add NEXT_PUBLIC_SUPABASE_URL or NEXT_PUBLIC_SUPABASE_ANON_KEY.
# Database access is backend-only.
